# Copy this file to .env and fill in the values

# Your backend API base URL
EXPO_PUBLIC_API_URL=http://localhost:3000

# Clerk publishable key — found in your Clerk dashboard under API Keys
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=""

# A unique identifier for the development user. This is used to simulate authentication in development mode.
# This is to be used when DEV_BYPASS_AUTH is set to "true". 
EXPO_PUBLIC_DEV_USER_ID="" 

# Mapbox public token — found in your Mapbox account dashboard
EXPO_PUBLIC_MAPBOX_TOKEN=""
RNMAPBOX_MAPS_DOWNLOAD_TOKEN=""
