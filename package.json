{
  "name": "drake-glazers",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "install:all": "npm install && npm install --prefix client && npm install --prefix server"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "commitlint": "^20.5.2",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0"
  },
  "lint-staged": {
    "client/**/*.{js,jsx,ts,tsx}": [
      "bash -c 'cd client && eslint --fix'",
      "prettier --write"
    ],
    "server/**/*.{js,ts}": [
      "bash -c 'cd server && eslint --fix'",
      "prettier --write"
    ]
  },
  "dependencies": {
    "expo-av": "^16.0.8",
    "expo-image-picker": "~55.0.19"
  }
}
